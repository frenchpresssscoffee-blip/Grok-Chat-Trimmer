{
  "manifest_version": 3,
  "name": "Speed Booster for Grok",
  "version": "2.0.0",
  "minimum_chrome_version": "88",
  "description": "Automatic performance optimization for Grok chats. Zero configuration required.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "*://grok.com/*",
    "*://grok.x.ai/*",
    "*://x.com/grok*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://grok.com/*",
        "*://grok.x.ai/*",
        "*://x.com/grok*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "manual-optimize": {
      "suggested_key": {
        "default": "Ctrl+Shift+O"
      },
      "description": "Force optimization now"
    },
    "toggle-extension": {
      "suggested_key": {
        "default": "Ctrl+Shift+P"
      },
      "description": "Pause/resume extension"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
